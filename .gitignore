# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# PM2 config and deploy scripts contain secrets — never commit
ecosystem.config.js
deploy.sh

# SSL/TLS keys
*.key

# Debug / local output files
dev_debug.log
media_debug.json
social_debug.json

# Claude Code internal state
.claude/

# Local helper scripts with embedded tokens
vp_ask2.bat

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
